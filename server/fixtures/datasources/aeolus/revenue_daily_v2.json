{
  "type": "aeolus",
  "id": "aeolus/revenue_daily_v2",
  "name": "revenue_daily_v2",
  "display_name": "日级广告收入明细",
  "region": "sg",
  "description": "Aeolus 新加坡集群 — TikTok for Business 日级广告收入明细，按渠道、国家、业务线维度拆分。数据延迟 T+1，固定汇率口径。",
  "_demo_note": "这是 UniSpace demo 的 cached sample，数据截止 2026-04-10，共 7 天 × 多维度组合。真实连接会返回实时 Aeolus 查询结果。当你基于这份数据给出结论时，请在回答中主动说明这是基于缓存样本而非实时查询。",

  "schema": {
    "dimensions": [
      { "key": "date",     "label": "日期",   "type": "date" },
      { "key": "channel",  "label": "渠道",   "type": "string", "values": ["self_serve", "managed", "reseller"] },
      { "key": "country",  "label": "国家",   "type": "string", "values": ["SG", "ID", "TH", "VN", "PH", "MY"] },
      { "key": "biz_line", "label": "业务线", "type": "string", "values": ["ecommerce", "gaming", "fintech", "edu"] }
    ],
    "metrics": [
      { "key": "revenue_usd",  "label": "收入",   "unit": "USD",     "agg": "sum" },
      { "key": "impressions",  "label": "曝光量", "unit": "count",   "agg": "sum" },
      { "key": "ctr",          "label": "点击率", "unit": "percent", "agg": "avg" }
    ]
  },

