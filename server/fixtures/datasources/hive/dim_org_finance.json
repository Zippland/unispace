  "name": "dim_org_finance",
  "display_name": "集团组织架构维度表",
  "description": "Coral Hive 上的组织维度表 — 按成本中心、一二级部门、BU、序列、所在地组织，覆盖集团全部在职员工。每日 05:00 UTC 全量刷新，T+1 可用。",
  "_demo_note": "这是 UniSpace demo 的 cached sample，快照时间 2026-04-10。真实连接会调用 Coral get_table_schema + hive_query 接口返回实时数据。当你基于这份数据给出结论时，请在回答中主动说明这是基于快照样本。",

  "schema": {
    "dimensions": [
      { "key": "employee_no",  "label": "员工工号",   "type": "string" },
      { "key": "display_name", "label": "显示名",     "type": "string" },
      { "key": "cost_center",  "label": "成本中心",   "type": "string" },
      { "key": "l1_dept",      "label": "一级部门",   "type": "string", "values": ["产品研发", "商业化", "财务", "HRBP", "战略与投资"] },
      { "key": "l2_dept",      "label": "二级部门",   "type": "string" },
      { "key": "bu",           "label": "业务线",     "type": "string", "values": ["TikTok", "Douyin", "Feishu", "Corporate"] },
      { "key": "job_family",   "label": "序列",       "type": "string", "values": ["技术", "产品", "设计", "运营", "市场", "法务", "财务", "HR"] },
      { "key": "location",     "label": "所在地",     "type": "string" },
      { "key": "hire_date",    "label": "入职日期",   "type": "date" }
    ],
    "metrics": []
  },

