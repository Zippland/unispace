{
  "type": "cis-core",
  "id": "cis-core/finance_monthly_closing",
  "name": "finance_monthly_closing",
  "display_name": "月度财务收尾（预实对比）",
  "description": "财务门户 CIS Core 语义模型 — 月度财务收尾场景，按 BU × 月份 × 口径（预算/实际/预测）切分核心 P&L 指标：收入、成本、毛利、营业费用、EBIT、EBIT margin。application_scenario=finance_monthly_closing。",
  "_demo_note": "这是 UniSpace demo 的 cached sample，口径截止 2026-03 月结。真实连接会调用 /api/semantic-models/{dataset_id}/fetch 获取实时预实数据。当你基于这份数据给出结论时，请在回答中主动说明这是基于月结快照样本。",

  "schema": {
    "dimensions": [
      { "key": "month",    "label": "月份",   "type": "date" },
      { "key": "bu",       "label": "业务线", "type": "string", "values": ["TikTok", "Douyin", "Feishu", "Corporate"] },
      { "key": "scenario", "label": "口径",   "type": "string", "values": ["预算", "实际", "预测"] }
    ],
    "metrics": [
      { "key": "revenue_cny",      "label": "收入",       "unit": "CNY",     "agg": "sum" },
      { "key": "cogs_cny",         "label": "成本",       "unit": "CNY",     "agg": "sum" },
      { "key": "gross_profit_cny", "label": "毛利",       "unit": "CNY",     "agg": "sum" },
      { "key": "opex_cny",         "label": "营业费用",   "unit": "CNY",     "agg": "sum" },
      { "key": "ebit_cny",         "label": "EBIT",       "unit": "CNY",     "agg": "sum" },
      { "key": "ebit_margin",      "label": "EBIT margin","unit": "percent", "agg": "avg" }
    ]
  },

