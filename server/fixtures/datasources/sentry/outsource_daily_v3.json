  "type": "sentry",
  "id": "sentry/outsource_daily_v3",
  "name": "outsource_daily_v3",
  "display_name": "外包成本分摊明细",
  "description": "Sentry 数据集 — 集团外包成本分摊明细，维度包括外包科目、成本中心、汇率口径、区域、序列。默认使用固定汇率，支持分摊前/后口径切换。数据来源 HR-ERP，月度冻结。",
  "_demo_note": "这是 UniSpace demo 的 cached sample，快照月份 2026-03。真实连接会读取 Sentry 的语义模型和 dim_values 缓存返回实时切片。注意：外包科目只能放在 view_axis_arr 中指定，不能用于 filter。当你基于这份数据给出结论时，请在回答中主动说明这是基于月度冻结的样本数据。",

  "schema": {
    "dimensions": [
      { "key": "month",              "label": "月份",       "type": "date" },
      { "key": "outsource_subject",  "label": "外包科目",   "type": "string", "values": ["外包HC", "人员外包与TPA成本", "设备外包", "IDC 运维外包", "专项项目外包"] },
      { "key": "cost_center",        "label": "成本中心",   "type": "string" },
      { "key": "data_source",        "label": "数据来源",   "type": "string", "values": ["分摊前", "分摊后"] },
      { "key": "exchange_rate_type", "label": "汇率口径",   "type": "string", "values": ["固定汇率", "实际汇率"] },
      { "key": "region",             "label": "区域",       "type": "string", "values": ["中国大陆", "新加坡", "美国", "加拿大", "英国"] },
      { "key": "job_family",         "label": "序列",       "type": "string", "values": ["技术", "运营", "市场", "安全", "法务", "财务"] }
    ],
    "metrics": [
      { "key": "cost_cny", "label": "成本",       "unit": "CNY", "agg": "sum" },
      { "key": "hc",       "label": "人头",       "unit": "count", "agg": "sum" },
      { "key": "mandays",  "label": "人天",       "unit": "count", "agg": "sum" }
    ]
  },

